0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.4189-2.1568 2.4189Z\" /></svg><span>Discord</span></li>\n        <li><svg viewBox=\"0 0 24 24\" role=\"img\" aria-label=\"Viber\"><path fill=\"currentColor\" d=\"M11.4 0C9.473.028 5.333.344 3.02 2.467 1.302 4.187.696 6.7.633 9.817.57 12.933.488 18.776 6.12 20.36h.003l-.004 2.416s-.037.977.61 1.177c.777.242 1.234-.5 1.98-1.302.407-.44.972-1.084 1.397-1.58 3.85.326 6.812-.416 7.15-.525.776-.252 5.176-.816 5.892-6.657.74-6.02-.36-9.83-2.34-11.546-.596-.55-3.006-2.3-8.375-2.323 0 0-.395-.025-1.037-.017zm.058 1.693c.545-.004.88.017.88.017 4.542.02 6.717 1.388 7.222 1.846 1.675 1.435 2.53 4.868 1.906 9.897v.002c-.604 4.878-4.174 5.184-4.832 5.395-.28.09-2.882.737-6.153.524 0 0-2.436 2.94-3.197 3.704-.12.12-.26.167-.352.144-.13-.033-.166-.188-.165-.414l.02-4.018c-4.762-1.32-4.485-6.292-4.43-8.895.054-2.604.543-4.738 1.996-6.173 1.96-1.773 5.474-2.018 7.11-2.03zm.38 2.602c-.167 0-.303.135-.304.302 0 .167.133.303.3.305 1.624.01 2.946.537 4.028 1.592 1.073 1.046 1.62 2.468 1.633 4.334.002.167.14.3.307.3.166-.002.3-.138.3-.304-.014-1.984-.618-3.596-1.816-4.764-1.19-1.16-2.692-1.753-4.447-1.765zm-3.96.695c-.19-.032-.4.005-.616.117l-.01.002c-.43.247-.816.562-1.146.932-.002.004-.006.004-.008.008-.267.323-.42.638-.46.948-.008.046-.01.093-.007.14 0 .136.022.27.065.4l.013.01c.135.48.473 1.276 1.205 2.604.42.768.903 1.5 1.446 2.186.27.344.56.673.87.984l.132.132c.31.308.64.6.984.87.686.543 1.418 1.027 2.186 1.447 1.328.733 2.126 1.07 2.604 1.206l.01.014c.13.042.265.064.402.063.046.002.092 0 .138-.008.31-.036.627-.19.948-.46.004 0 .003-.002.008-.005.37-.33.683-.72.93-1.148l.003-.01c.225-.432.15-.842-.18-1.12-.004 0-.698-.58-1.037-.83-.36-.255-.73-.492-1.113-.71-.51-.285-1.032-.106-1.248.174l-.447.564c-.23.283-.657.246-.657.246-3.12-.796-3.955-3.955-3.955-3.955s-.037-.426.248-.656l.563-.448c.277-.215.456-.737.17-1.248-.217-.383-.454-.756-.71-1.115-.25-.34-.826-1.033-.83-1.035-.137-.165-.31-.265-.502-.297zm4.49.88c-.158.002-.29.124-.3.282-.01.167.115.312.282.324 1.16.085 2.017.466 2.645 1.15.63.688.93 1.524.906 2.57-.002.168.13.306.3.31.166.003.305-.13.31-.297.025-1.175-.334-2.193-1.067-2.994-.74-.81-1.777-1.253-3.05-1.346h-.024zm.463 1.63c-.16.002-.29.127-.3.287-.008.167.12.31.288.32.523.028.875.175 1.113.422.24.245.388.62.416 1.164.01.167.15.295.318.287.167-.008.295-.15.287-.317-.03-.644-.215-1.178-.58-1.557-.367-.378-.893-.574-1.52-.607h-.018z\" /></svg><span>Viber</span></li>\n        </ul>\n        \n      </div>\n    <p>Across all your messengers. In your browser today. In your keyboard next.</p>\n  </section>\n\n\n  <!-- ── How ──────────────────────────────────────────────────── -->\n  <section id=\"how\">\n    <p>HOW IT WORKS</p>\n    <h2>Three steps. Then forget it's there.</h2>\n    <div>\n      <div>\n        <p>1</p>\n        <h3>Claim your handle</h3>\n        <p>Keys are generated on your device, sealed by your passphrase. Grab <em>@you</em>, or stay completely anonymous.</p>\n        \n      </div>\n      <div>\n        <p>2</p>\n        <h3>Sync your people</h3>\n        <p>Your private key never leaves your device. Ekko only publishes the <em>public</em> key people need to reach you. It never uploads the key that opens your messages.</p>\n        \n      </div>\n      <div>\n        <p>3</p>\n        <h3>Write where you already chat</h3>\n        <p>The mark sits at the end of the box. It names who it is sealing to, checks their key, and the words leave encrypted. In your browser today, in your keyboard next.</p>\n        \n      </div>\n    </div>\n  </section>\n\n  <hr>\n\n  <!-- ── Two modes ────────────────────────────────────────────── -->\n  <section id=\"modes\">\n    <p>TWO WAYS TO USE IT</p>\n    <h2>Claim a handle. Or stay a ghost.</h2>\n    <div>\n      <div>\n        <h3>@you, everywhere</h3>\n        <p>Claim your handle once, link your socials, and add friends everywhere. They find your public key automatically. Every app you share becomes a sealed channel.</p>\n      </div>\n      <div>\n        <h3>Off the grid</h3>\n        <p>No handle, no sign-in, nothing to join. Generate keys on your device and trade invites directly with the people you trust. We never even learn you exist.</p>\n      </div>\n    </div>\n  </section>\n\n  <hr>\n\n  <!-- ── FAQ ──────────────────────────────────────────────────── -->\n  <section id=\"faq\">\n    <p>FAQ</p>\n    <h2>Frequently asked questions.</h2>\n    <div>\n      <details name=\"faq\">\n        <summary>Is Ekko another messenger I have to move people to?</summary>\n        <p>No, and that's the whole point. Ekko is a layer over the apps you already use. Your chats stay exactly where they are. The words inside them just stop being readable to anyone but the person you wrote to.</p>\n      </details>\n      <details name=\"faq\">\n        <summary>What do Ekko's servers actually see?</summary>\n        <p>Handles and public keys. That's the entire directory. Your private keys are generated and stay on your device, and your messages travel through your apps as sealed ciphertext, never through us.</p>\n      </details>\n      <details name=\"faq\">\n        <summary>Do I need an account?</summary>\n        <p>Only if you want one. Claim a handle so friends find your key automatically, or stay off the grid entirely and trade invites by hand. Both modes are first-class.</p>\n      </details>\n      <details name=\"faq\">\n        <summary>What does \"post-quantum\" mean here?</summary>\n        <p>Every message is sealed with a hybrid of X25519 and ML-KEM-768 with XChaCha20-Poly1305. Anything recorded today stays unreadable, even to a future quantum computer. The protocol spec is public.</p>\n      </details>\n      <details name=\"faq\">\n        <summary>Which apps does Ekko work with?</summary>\n        <p>The ones you already have. Ekko rides on top of Instagram, WhatsApp, Telegram, X, Messenger and more: it starts in your browser and unlocks messengers in waves, with your phone's keyboard next. Subscribe to the newsletter and you're first to hear as each one lights up.</p>\n      </details>\n      <details name=\"faq\">\n        <summary>Is it free?</summary>\n        <p>Yes. The code is open source, so the basic functionality stays available forever.</p>\n      </details>\n    </div>\n  </section>\n\n  <hr>\n\n  <!-- ── Get Ekko ─────────────────────────────────────────────── -->\n  <section id=\"get\">\n    <h2>Take privacy back.</h2>\n    \n    \n  </section>\n\n</DIV></DIV>","content_text":"Post-quantum encryption, right where you already type. No new messenger, and nobody to talk into switching. Private messages, right where you already chat. Animated demonstration: Ekko seals a one-to-one message on the sender's device and opens it in the recipient's chat. Instagram WhatsApp Telegram Messages X Messenger Discord Viber Across all your messengers. In your browser today. In your keyboard next. HOW IT WORKS Three steps. Then forget it's there. 1 Claim your handle Keys are generated on your device, sealed by your passphrase. Grab @you, or stay completely anonymous. 2 Sync your people Your private key never leaves your device. Ekko only publishes the public key people need to reach you. It never uploads the key that opens your messages. 3 Write where you already chat The mark sits at the end of the box. It names who it is sealing to, checks their key, and the words leave encrypted. In your browser today, in your keyboard next. TWO WAYS TO USE IT Claim a handle. Or stay a ghost. @you, everywhere Claim your handle once, link your socials, and add friends everywhere. They find your public key automatically. Every app you share becomes a sealed channel. Off the grid No handle, no sign-in, nothing to join. Generate keys on your device and trade invites directly with the people you trust. We never even learn you exist. FAQ Frequently asked questions. Is Ekko another messenger I have to move people to? No, and that's the whole point. Ekko is a layer over the apps you already use. Your chats stay exactly where they are. The words inside them just stop being readable to anyone but the person you wrote to. What do Ekko's servers actually see? Handles and public keys. That's the entire directory. Your private keys are generated and stay on your device, and your messages travel through your apps as sealed ciphertext, never through us. Do I need an account? Only if you want one. Claim a handle so friends find your key automatically, or stay off the grid entirely and trade invites by hand. Both modes are first-class. What does \"post-quantum\" mean here? Every message is sealed with a hybrid of X25519 and ML-KEM-768 with XChaCha20-Poly1305. Anything recorded today stays unreadable, even to a future quantum computer. The protocol spec is public. Which apps does Ekko work with? The ones you already have. Ekko rides on top of Instagram, WhatsApp, Telegram, X, Messenger and more: it starts in your browser and unlocks messengers in waves, with your phone's keyboard next. Subscribe to the newsletter and you're first to hear as each one lights up. Is it free? Yes. The code is open source, so the basic functionality stays available forever. Take privacy back.","fetched_at":"2026-07-22T00:38:03.435Z","ok":true,"blocks":[{"html_en":"<p>\n      Post-quantum encryption, right where you already type. No new messenger,\n      and nobody to talk into switching.\n    </p>","sentences":[{"en":"Post-quantum encryption, right where you already type.","zh":"后量子加密，就在您已​​经输入的地方。"},{"en":"No new messenger, and nobody to talk into switching.","zh":"没有新的信使，也没有人可以谈论切换。"}]},{"html_en":"<figcaption>Private messages, right where you already chat.</figcaption>","sentences":[{"en":"Private messages, right where you already chat.","zh":"私人消息，就在您已​​经聊天的地方。"}]},{"html_en":"<p>Animated demonstration: Ekko seals a one-to-one message on the sender's device and opens it in the recipient's chat.</p>","sentences":[{"en":"Animated demonstration: Ekko seals a one-to-one message on the sender's device and opens it in the recipient's chat.","zh":"动画演示：Ekko 在发送者的设备上密封一对一消息，并在接收者的聊天中打开它。"}]},{"html_en":"<li><svg viewBox=\"0 0 24 24\" role=\"img\" aria-label=\"Instagram\"><path fill=\"currentColor\" d=\"M7.0301.084c-1.2768.0602-2.1487.264-2.911.5634-.7888.3075-1.4575.72-2.1228 1.3877-.6652.6677-1.075 1.3368-1.3802 2.127-.2954.7638-.4956 1.6365-.552 2.914-.0564 1.2775-.0689 1.6882-.0626 4.947.0062 3.2586.0206 3.6671.0825 4.9473.061 1.2765.264 2.1482.5635 2.9107.308.7889.72 1.4573 1.388 2.1228.6679.6655 1.3365 1.0743 2.1285 1.38.7632.295 1.6361.4961 2.9134.552 1.2773.056 1.6884.069 4.9462.0627 3.2578-.0062 3.668-.0207 4.9478-.0814 1.28-.0607 2.147-.2652 2.9098-.5633.7889-.3086 1.4578-.72 2.1228-1.3881.665-.6682 1.0745-1.3378 1.3795-2.1284.2957-.7632.4966-1.636.552-2.9124.056-1.2809.0692-1.6898.063-4.948-.0063-3.2583-.021-3.6668-.0817-4.9465-.0607-1.2797-.264-2.1487-.5633-2.9117-.3084-.7889-.72-1.4568-1.3876-2.1228C21.2982 1.33 20.628.9208 19.8378.6165 19.074.321 18.2017.1197 16.9244.0645 15.6471.0093 15.236-.005 11.977.0014 8.718.0076 8.31.0215 7.0301.0839m.1402 21.6932c-1.17-.0509-1.8053-.2453-2.2287-.408-.5606-.216-.96-.4771-1.3819-.895-.422-.4178-.6811-.8186-.9-1.378-.1644-.4234-.3624-1.058-.4171-2.228-.0595-1.2645-.072-1.6442-.079-4.848-.007-3.2037.0053-3.583.0607-4.848.05-1.169.2456-1.805.408-2.2282.216-.5613.4762-.96.895-1.3816.4188-.4217.8184-.6814 1.3783-.9003.423-.1651 1.0575-.3614 2.227-.4171 1.2655-.06 1.6447-.072 4.848-.079 3.2033-.007 3.5835.005 4.8495.0608 1.169.0508 1.8053.2445 2.228.408.5608.216.96.4754 1.3816.895.4217.4194.6816.8176.9005 1.3787.1653.4217.3617 1.056.4169 2.2263.0602 1.2655.0739 1.645.0796 4.848.0058 3.203-.0055 3.5834-.061 4.848-.051 1.17-.245 1.8055-.408 2.2294-.216.5604-.4763.96-.8954 1.3814-.419.4215-.8181.6811-1.3783.9-.4224.1649-1.0577.3617-2.2262.4174-1.2656.0595-1.6448.072-4.8493.079-3.2045.007-3.5825-.006-4.848-.0608M